rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{allPaths=**} {
      allow read: if true; // Or restrict to project access if metadata is added
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }
    
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false; // Deny other writes
    }
  }
}
